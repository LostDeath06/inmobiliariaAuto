# =============================================================================
#  CONFIGURACIÓN DE ENTORNO  —  copia este archivo a `.env` y rellena los valores
#  NUNCA subas `.env` al repositorio. NUNCA pongas secretos reales aquí.
#
#  El mismo fichero sirve para los dos entornos. Lo que cambia va marcado con
#  [LOCAL] (tu Windows) y [VPS]. Procedimiento completo del VPS: DESPLIEGUE.md
# =============================================================================

# --- ACCESO A LA APLICACIÓN  ([VPS] obligatorio) ----------------------------
# Contraseña de acceso a TODA la app (web + API + /docs). La pide el navegador.
# Sin ella el contenedor del frontend NO arranca: es a propósito, para que el
# sistema no pueda quedar expuesto a internet sin credenciales.
# Para CAMBIARLA: edita APP_PASSWORD y ejecuta en el VPS
#     docker compose up -d --force-recreate frontend
APP_USUARIO=admin
APP_PASSWORD=

# --- Credencial de SOLO LECTURA (bot de consulta: OpenClaw / Telegram) -------
# Abre únicamente /api-lectura/, que nginx limita a GET/HEAD: con ella NO se
# puede crear búsquedas, borrar inmuebles, cambiar configuración ni lanzar jobs.
# Es distinta de APP_PASSWORD a propósito: la del bot no entra en la app, y la
# de admin no hay que dársela al bot.
# Opcional: si la dejas vacía, /api-lectura/ queda deshabilitada.
# Genera una larga:  openssl rand -base64 32
CONSULTA_USUARIO=consulta
CONSULTA_PASSWORD=

# Puerto público por el que se sirve la app  (80 => http://IP_DEL_VPS/ )
PUERTO_HTTP=80

# --- Perfil de docker compose -----------------------------------------------
# [VPS] Descomenta para que `docker compose up -d` levante las 4 piezas.
# [LOCAL] Déjalo comentado: `docker compose up -d` levanta solo Postgres y
#         sigues usando ARRANCAR.bat para backend y frontend.
# COMPOSE_PROFILES=vps

# --- Base de datos -----------------------------------------------------------
# Credenciales del contenedor de Postgres. [VPS] CAMBIA la contraseña.
POSTGRES_USER=inmo
POSTGRES_PASSWORD=inmo
POSTGRES_DB=inmobiliaria

# Puerto de Postgres, publicado SOLO en 127.0.0.1 (no llega desde internet).
PUERTO_DB=5455

# [LOCAL] Cadena que usan uvicorn y pytest al correr en Windows.
# [VPS] No la toques: docker compose la sobreescribe apuntando al contenedor `db`.
DATABASE_URL=postgresql://inmo:inmo@localhost:5455/inmobiliaria

# Tamaño del pool de conexiones asyncpg
DB_POOL_MIN=2
DB_POOL_MAX=10

# --- Anthropic (analista cualitativo) ----------------------------------------
# Obligatoria para rankear: sin ella el análisis falla y los inmuebles quedan
# NO_CALCULABLE. Solo juicio cualitativo; NUNCA cálculos financieros.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5
ANTHROPIC_MAX_TOKENS=4096

# --- OpenClaw (agente de scraping externo) -----------------------------------
# manual = por ahora: copias el prompt en el Monitor y pegas el JSON de vuelta.
# http   = el backend llama a OpenClaw automáticamente 24/7.
OPENCLAW_MODE=manual

# CUANDO MONTES OPENCLAW EN ESTE MISMO VPS, el cambio exacto es:
#   1. OPENCLAW_MODE=http
#   2. OPENCLAW_BASE_URL=http://host.docker.internal:8080   (ajusta el puerto)
#   3. OPENCLAW_API_KEY=...   si tu adaptador exige Bearer
#   4. OPENCLAW_AGENT_ID=inmobiliaria-scraper  (agente podado: ver más abajo)
#   5. docker compose up -d --force-recreate backend worker
#
# OJO, el matiz que rompe esto: dentro de un contenedor `localhost` es el PROPIO
# contenedor, no el VPS. Si OpenClaw corre en el host (fuera de Docker) usa
# host.docker.internal — ya está cableado en docker-compose.yml con extra_hosts.
# Si lo añades como un servicio más del compose, usa el nombre del servicio
# (p. ej. http://openclaw:8080).
OPENCLAW_BASE_URL=http://host.docker.internal:8080
# Agente dedicado y PODADO para scraping (ver docs/OPENCLAW_COSTES.md).
# Sin esto se usa el agente por defecto, con 16 skills y 7 ficheros de
# workspace inyectados: ~19.000 tokens de caché por job antes de empezar.
OPENCLAW_AGENT_ID=
OPENCLAW_API_KEY=
OPENCLAW_TIMEOUT_SEGUNDOS=900
OPENCLAW_MAX_REINTENTOS=3
# Límite de anuncios a extraer por job (controla coste y tiempo)
OPENCLAW_LIMITE_ANUNCIOS=50

# --- Worker de jobs ----------------------------------------------------------
WORKER_INTERVALO_SONDEO_SEGUNDOS=15
WORKER_JOBS_CONCURRENTES=3

# --- Aplicación --------------------------------------------------------------
ENTORNO=desarrollo
LOG_NIVEL=INFO
API_HOST=0.0.0.0
API_PUERTO=8000

# --- Multi-tenant (preparado, NO implementado) -------------------------------
PROPIETARIO_POR_DEFECTO=00000000-0000-0000-0000-000000000001
