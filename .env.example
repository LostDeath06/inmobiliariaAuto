# =============================================================================
#  CONFIGURACIÓN DE ENTORNO  —  copia este archivo a `.env` y rellena los valores
#  NUNCA subas `.env` al repositorio. NUNCA pongas secretos reales aquí.
# =============================================================================

# --- Base de datos (Supabase / PostgreSQL) ----------------------------------
# Cadena de conexión directa a Postgres (la que da Supabase en "Connection string").
# En desarrollo local con docker-compose: postgresql://inmo:inmo@localhost:5455/inmobiliaria
DATABASE_URL=postgresql://inmo:inmo@localhost:5455/inmobiliaria

# Tamaño del pool de conexiones asyncpg
DB_POOL_MIN=2
DB_POOL_MAX=10

# --- Anthropic (analista cualitativo, Fase 6) -------------------------------
# Solo juicio cualitativo estructurado. NUNCA cálculos financieros.
ANTHROPIC_API_KEY=
# Modelo del analista. Elegido: claude-sonnet-5 (respuesta 8B).
ANTHROPIC_MODEL=claude-sonnet-5
ANTHROPIC_MAX_TOKENS=4096

# --- OpenClaw (agente de scraping externo, Fase 5) --------------------------
# Modo de operación:
#   http   = producción, el cliente llama al VPS automáticamente 24/7
#   manual = desarrollo, se muestra el prompt para copiar y se pega el JSON de vuelta
OPENCLAW_MODE=manual
OPENCLAW_BASE_URL=http://TU_VPS_HOSTINGER:8080
OPENCLAW_API_KEY=
OPENCLAW_TIMEOUT_SEGUNDOS=900
OPENCLAW_MAX_REINTENTOS=3
# Límite de anuncios a extraer por job (controla coste y tiempo)
OPENCLAW_LIMITE_ANUNCIOS=50

# --- Worker de jobs (Fase 7) ------------------------------------------------
# APScheduler embebido; sin Redis ni Celery (respuesta 7A).
WORKER_INTERVALO_SONDEO_SEGUNDOS=15
WORKER_JOBS_CONCURRENTES=3

# --- Aplicación -------------------------------------------------------------
ENTORNO=desarrollo
LOG_NIVEL=INFO
API_HOST=0.0.0.0
API_PUERTO=8000

# --- Multi-tenant (preparado, NO implementado — respuesta 4A) ---------------
# En mono-usuario auto-hospedado este valor se aplica como propietario por defecto.
# Cuando se active multi-tenant, se poblará por sesión de usuario autenticado.
PROPIETARIO_POR_DEFECTO=00000000-0000-0000-0000-000000000001
